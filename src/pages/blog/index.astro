---
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import SocialList from "@/components/SocialList";
import { getAllPosts, sortMDByDate } from "@/utils";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);

---

<PageLayout meta={{ title: "Blog" }}>
	<section>
		<h1 class="title mb-6"><span class="cli-color-main-blue">echo</span> <span id="var-name">$greetings</span></h1>
		<p class="mb-4" id="var-text">
			Hi! We are CLi.
		</p>
		<SocialList />
	</section>
	<section aria-label="Blog post list" class="mt-16">
		<h2 class="title mb-4 text-xl">Posts</h2>
		<ul class="space-y-4 sm:space-y-2">
			{
				allPostsByDate.map((p) => (
					<li class="flex flex-col gap-x-2 sm:flex-row">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<script>
	const pairs = [
		{ var: "$greetings", text: "Hi! We are CLi." },
		{ var: "$mission", text: "We build civic data tools." },
		{ var: "$approach", text: "Capacity-building with care." },
		{ var: "$focus", text: "Open data for civic impact." },
	];

	const pick = pairs[Math.floor(Math.random() * pairs.length)];
	document.getElementById("var-name").textContent = pick.var;
	document.getElementById("var-text").textContent = pick.text;
</script>
